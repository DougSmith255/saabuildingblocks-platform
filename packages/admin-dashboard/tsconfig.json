{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@saa/shared/*": ["../../packages/shared/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../shared/styled-jsx.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "workers",
    "scripts"
  ]
}
