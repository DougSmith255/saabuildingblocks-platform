---
/**
 * Homepage - Astro-native rebuild
 *
 * Architecture: Static Astro HTML for all sections where possible.
 * React islands only for interactive elements that require JS:
 * - Header (scroll behavior, mobile menu)
 * - Footer (interactive elements)
 * - JoinCTA button (modal trigger)
 * - WhyOnlyAtExp (auto-flip card stack)
 * - MediaLogos (RAF-driven scrolling carousel)
 * - BuiltForFuture (carousel + data stream background)
 * - WatchAndDecide (video player + progress tracking)
 *
 * Section order matches production HomepageSections.tsx:
 * Hero > ValuePillarsTab > WhySAA > ProvenAtScale > WhatYouGet >
 * WhyOnlyAtExp > MediaLogos > MeetTheFounders > BuiltForFuture >
 * WatchAndDecide (in GlassPanel) > Bottom CTA
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ValuePillarsTab from '../components/sections/ValuePillarsTab.astro';
import WhySAA from '../components/sections/WhySAA.astro';
import ProvenAtScale from '../components/sections/ProvenAtScale.astro';
import WhatYouGet from '../components/sections/WhatYouGet.astro';
import MeetTheFounders from '../components/sections/MeetTheFounders.astro';
import HeaderIsland from '../islands/header';
import FooterIsland from '../islands/footer';
import JoinCTA from '../islands/join-cta';
import WhyOnlyAtExpIsland from '../islands/why-only-at-exp';
import MediaLogosIsland from '../islands/media-logos';
import BuiltForFutureIsland from '../islands/built-for-future';
import WatchAndDecideIsland from '../islands/watch-and-decide';

// GlassPanel champagne styles (inlined for the WatchAndDecide wrapper)
const champagneBg = 'linear-gradient(180deg, rgba(247,231,206,0.04) 0%, rgba(247,231,206,0.05) 50%, rgba(247,231,206,0.04) 100%)';
const champagneShadow = '0 8px 32px rgba(0,0,0,0.4), 0 4px 12px rgba(0,0,0,0.25), inset 0 1px 0 0 rgba(255,255,255,0.35), inset 0 2px 4px 0 rgba(255,255,255,0.2), inset 0 8px 20px -8px rgba(247,231,206,0.3), inset 0 20px 40px -20px rgba(255,255,255,0.15), inset 0 -1px 0 0 rgba(0,0,0,0.7), inset 0 -2px 6px 0 rgba(0,0,0,0.5), inset 0 -10px 25px -8px rgba(0,0,0,0.6), inset 0 -25px 50px -20px rgba(0,0,0,0.45)';
---

<BaseLayout
  title="Smart Agent Alliance - For Agents Who Want More"
  description="Join the Smart Agent Alliance and eXp Realty to build your real estate career with industry-leading commission splits, revenue share, and mentorship from Doug Smart and Karrie Hill."
  canonical="/"
>
  <!-- Preload LCP image -->
  <link slot="head" rel="preload" as="image" href="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop" imagesrcset="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/mobile 375w, https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/tablet 768w, https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop 1280w" imagesizes="(max-width: 480px) 375px, (max-width: 768px) 768px, 1280px" />

  <!-- Header - React island for interactive scroll behavior -->
  <HeaderIsland client:load />

  <main id="main-content">
    <!-- Hero Section - static Astro HTML -->
    <HeroSection>
      <JoinCTA client:idle slot="cta">JOIN THE ALLIANCE</JoinCTA>
    </HeroSection>

    <!-- ValuePillarsTab - static (01, 02, 03 pillars) -->
    <ValuePillarsTab />

    <!-- WhySAA - static bento grid -->
    <WhySAA />

    <!-- ProvenAtScale - static with wolf pack bg -->
    <ProvenAtScale />

    <!-- WhatYouGet - static with CSS orbital rings -->
    <WhatYouGet />

    <!-- WhyOnlyAtExp - React island (auto-flip card stack) -->
    <WhyOnlyAtExpIsland client:visible />

    <!-- MediaLogos - React island (RAF scrolling carousel) -->
    <MediaLogosIsland client:visible />

    <!-- MeetTheFounders - static -->
    <MeetTheFounders variant="compact" />

    <!-- BuiltForFuture - React island (carousel + data stream) -->
    <BuiltForFutureIsland client:visible />

    <!-- WatchAndDecide - wrapped in GlassPanel champagne -->
    <div
      class="relative overflow-hidden rounded-3xl"
      style={`background: ${champagneBg}; box-shadow: ${champagneShadow};`}
    >
      <!-- Dots texture -->
      <div
        class="absolute inset-0 pointer-events-none z-[1] rounded-3xl"
        style="background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 8px 8px;"
      ></div>
      <div class="relative z-10">
        <WatchAndDecideIsland client:visible />
      </div>
    </div>

    <!-- Bottom CTA -->
    <section class="py-16 md:py-20 px-6 text-center">
      <p class="text-body mx-auto mb-8" style="max-width: 700px;">
        If you want to understand exactly how sponsorship works, what you keep, and what you never give up, see how Smart Agent Alliance fits inside eXp Realty.
      </p>
      <a
        href="/exp-realty-sponsor/"
        class="inline-flex items-center justify-center relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-l before:from-white/15 before:to-transparent before:w-1/2 before:skew-x-[45deg]"
        style="color: var(--text-color-secondaryButton, var(--text-color-button, var(--color-headingText))); font-size: var(--font-size-secondaryButton, var(--font-size-button, 20px)); font-family: var(--font-family-secondaryButton, var(--font-family-button, var(--font-taskor), Taskor, system-ui, sans-serif)); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; line-height: 1; height: clamp(35px, calc(33.182px + 0.7273vw), 55px); padding-left: 1.25rem; padding-right: 1.25rem; padding-top: 0.5rem; padding-bottom: 0.5rem; background-color: rgb(45,45,45); border-radius: 0.75rem; box-shadow: 0 15px 15px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1), inset 0 -1px 0 rgba(0,0,0,0.5); white-space: nowrap;"
      >
        See SAA&apos;s Full Value Stack
      </a>
    </section>
  </main>

  <!-- Footer - React island -->
  <FooterIsland client:idle />
</BaseLayout>
