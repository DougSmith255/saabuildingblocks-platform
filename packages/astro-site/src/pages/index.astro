---
/**
 * Homepage - Astro-native rebuild
 *
 * Architecture: Static Astro HTML for all sections where possible.
 * React islands only for elements that truly require React:
 * - Header (scroll behavior, mobile menu, join modal)
 * - WatchAndDecide (video player + progress tracking)
 *
 * Everything else is pure Astro (zero JS or tiny inline scripts):
 * - Footer, ScrollIndicator, JoinCTAButton, all content sections
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ValuePillarsTab from '../components/sections/ValuePillarsTab.astro';
import WhySAA from '../components/sections/WhySAA.astro';
import ProvenAtScale from '../components/sections/ProvenAtScale.astro';
import WhatYouGet from '../components/sections/WhatYouGet.astro';
import MeetTheFounders from '../components/sections/MeetTheFounders.astro';
import HeaderIsland from '../islands/header';
import Footer from '../components/Footer.astro';
import JoinCTAButton from '../components/JoinCTAButton.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import RevealMaskEffectIsland from '../islands/reveal-mask-effect';
import WhyOnlyAtExp from '../components/sections/WhyOnlyAtExp.astro';
import MediaLogos from '../components/sections/MediaLogos.astro';
import BuiltForFuture from '../components/sections/BuiltForFuture.astro';
import WatchAndDecideIsland from '../islands/watch-and-decide';
import SecondaryButton from '../components/saa/buttons/SecondaryButton.astro';

// GlassPanel gold styles (matching WhyOnlyAtExp panel)
const glassBg = 'linear-gradient(180deg, rgba(255,215,0,0.03) 0%, rgba(255,215,0,0.04) 50%, rgba(255,215,0,0.03) 100%)';
const glassShadow = '0 8px 32px rgba(0,0,0,0.4), 0 4px 12px rgba(0,0,0,0.25), inset 0 1px 0 0 rgba(255,255,255,0.35), inset 0 2px 4px 0 rgba(255,255,255,0.2), inset 0 8px 20px -8px rgba(255,215,0,0.25), inset 0 20px 40px -20px rgba(255,255,255,0.15), inset 0 -1px 0 0 rgba(0,0,0,0.7), inset 0 -2px 6px 0 rgba(0,0,0,0.5), inset 0 -10px 25px -8px rgba(0,0,0,0.6), inset 0 -25px 50px -20px rgba(0,0,0,0.45)';
---

<BaseLayout
  title="Smart Agent Alliance - For Agents Who Want More"
  description="Join the Smart Agent Alliance and eXp Realty to build your real estate career with industry-leading commission splits, revenue share, and mentorship from Doug Smart and Karrie Hill."
  canonical="/"
>
  <!-- Preload LCP image -->
  <link slot="head" rel="preload" as="image" href="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop" imagesrcset="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/mobile 375w, https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/tablet 768w, https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop 1280w" imagesizes="(max-width: 480px) 375px, (max-width: 768px) 768px, 1280px" />

  <!-- Smooth scroll (Lenis) - bundled script, no React -->
  <SmoothScroll />

  <!-- Scroll indicator - pure Astro + inline script -->
  <ScrollIndicator />

  <!-- Header - React island for interactive scroll behavior -->
  <HeaderIsland client:idle />

  <main id="main-content">
    <!-- Hero Section - static Astro HTML + RevealMaskEffect golden glow -->
    <HeroSection>
      <RevealMaskEffectIsland client:idle slot="effect" />
      <JoinCTAButton slot="cta">JOIN THE ALLIANCE</JoinCTAButton>
    </HeroSection>

    <!-- ValuePillarsTab - static (01, 02, 03 pillars) -->
    <ValuePillarsTab />

    <!-- WhySAA - static bento grid -->
    <WhySAA />

    <!-- ProvenAtScale - static with wolf pack bg -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 800px;">
      <ProvenAtScale />
    </div>

    <!-- WhatYouGet - static with CSS orbital rings -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 900px;">
      <WhatYouGet />
    </div>

    <!-- WhyOnlyAtExp - Astro + inline script (auto-flip card stack) -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 700px;">
      <WhyOnlyAtExp />
    </div>

    <!-- MediaLogos - static Astro (CSS-only scrolling carousel) -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 200px;">
      <MediaLogos />
    </div>

    <!-- MeetTheFounders - static -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 500px;">
      <MeetTheFounders variant="compact" />
    </div>

    <!-- BuiltForFuture - Astro + inline script (carousel + CSS data stream) -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 800px;">
      <BuiltForFuture />
    </div>

    <!-- WatchAndDecide - wrapped in gold-tinted glass panel -->
    <div
      class="cv-auto relative overflow-hidden rounded-3xl"
      style={`contain-intrinsic-size: auto 600px; background: ${glassBg}; box-shadow: ${glassShadow};`}
    >
      <!-- Crosshatch texture -->
      <div
        class="absolute inset-0 pointer-events-none z-[1] rounded-3xl"
        style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.08) 0px, transparent 1px, transparent 6px), repeating-linear-gradient(-45deg, rgba(255,255,255,0.08) 0px, transparent 1px, transparent 6px); background-size: 16px 16px;"
      ></div>
      <div class="relative z-10">
        <WatchAndDecideIsland client:visible />
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="cv-auto" style="contain-intrinsic-size: auto 200px;">
      <section class="py-16 md:py-20 px-6 text-center">
        <p class="text-body mx-auto mb-8" style="max-width: 700px;">
          If you want to understand exactly how sponsorship works, what you keep, and what you never give up, see how Smart Agent Alliance fits inside eXp Realty.
        </p>
        <SecondaryButton href="/exp-realty-sponsor/">See SAA's Value Stack</SecondaryButton>
      </section>
    </div>
  </main>

  <!-- Footer - pure Astro, zero JS -->
  <Footer />
</BaseLayout>

<style>
  /* Defer rendering of below-fold sections until near viewport.
     Reduces initial style+layout from ~1400ms to ~400ms on mobile. */
  .cv-auto {
    content-visibility: auto;
  }
</style>
