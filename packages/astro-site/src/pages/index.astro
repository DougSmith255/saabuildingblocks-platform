---
/**
 * Homepage - Smart Agent Alliance
 *
 * Hero rendered as static HTML for instant LCP.
 * Interactive elements hydrated as React islands.
 * Below-fold sections lazy-loaded via client:visible.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import H1 from '@saa/shared/components/saa/headings/H1';
import Tagline from '@saa/shared/components/saa/headings/Tagline';
import { JoinAllianceCTA } from '../components/react/JoinAllianceCTA';
import { RevealMaskEffect } from '@public-site/components/shared/RevealMaskEffect';
import { CounterAnimation } from '@public-site/app/components/CounterAnimation';
import { HomepageSections } from '../components/react/homepage/HomepageSections';
---

<BaseLayout
  title="Smart Agent Alliance - For Agents Who Want More"
  description="Join the Smart Agent Alliance and eXp Realty to build your real estate career with industry-leading commission splits, revenue share, and mentorship from Doug Smart and Karrie Hill."
>
  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative">
      <!-- HeroSettlingMask - CSS-only layout shift prevention -->
      <style>
        @keyframes hero-settle-fade {
          0%, 40% { opacity: 1; }
          100% { opacity: 0; }
        }
        .hero-settling-mask {
          position: fixed;
          inset: 0;
          z-index: 10000;
          background-color: #0a0a0a;
          pointer-events: none;
          animation: hero-settle-fade 500ms ease-out forwards;
        }
      </style>
      <div class="hero-settling-mask" aria-hidden="true"></div>

      <section
        class="relative min-h-[100dvh] w-full"
        aria-label="Hero"
        style={{
          maxWidth: '3000px',
          margin: '0 auto',
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          justifyContent: 'center',
          overflow: 'visible',
        }}
      >
        <!-- Agent Counter (Desktop) - CSS media query handles visibility -->
        <style>
          .agent-counter-wrapper { opacity: 1; }
          .tagline-counter-suffix { display: none !important; }
          @media (max-width: 1499px) {
            .agent-counter-wrapper { display: none !important; }
            .tagline-counter-suffix { display: inline-flex !important; }
          }
        </style>
        <div
          class="agent-counter-wrapper absolute z-50 left-2 lg:left-auto lg:right-8"
          style={{ top: '130px' }}
        >
          <span style={{
            display: 'inline-flex',
            alignItems: 'center',
            gap: '0.25em',
            fontSize: 'clamp(1.75rem, 2.625vw, 2.1875rem)',
          }}>
            <span
              class="counter-numbers-mobile"
              style={{
                display: 'inline',
                color: '#e5e4dd',
                fontFamily: 'var(--font-synonym), monospace',
                fontWeight: '300',
                fontSize: 'calc(1em + 10px)',
                textShadow: 'none',
              }}
            >
              <span class="counter-digit">4</span>
              <span class="counter-digit">0</span>
              <span class="counter-digit">0</span>
              <span class="counter-digit">0</span>
              <span>+</span>
            </span>
            <span style={{
              color: '#e5e4dd',
              fontFamily: 'var(--font-taskor), sans-serif',
              fontFeatureSettings: '"ss01" 1',
              textTransform: 'uppercase',
              letterSpacing: '0.05em',
              transform: 'perspective(800px) rotateX(8deg)',
              display: 'inline-block',
              position: 'relative',
              fontWeight: '700',
              textShadow: '0.005em 0.007em 0 #dddcd5, 0.010em 0.015em 0 #d5d4cb, 0.015em 0.025em 0 #cccbc2, 0.019em 0.035em 0 #c2c1b8, 0.023em 0.045em 0 #b8b7ae, 0.027em 0.055em 0 #abaa9f, 0.031em 0.065em 0 #a09f94, 0.034em 0.073em 0 #96958a, 0.037em 0.080em 0 #8d8c80, 0.040em 0.088em 0 #7a7970',
            }}>AGENTS</span>
          </span>
        </div>

        <!-- RevealMaskEffect - Golden glow animation (decorative) -->
        <RevealMaskEffect client:idle />

        <!-- Hero Content Block -->
        <div
          class="hero-content-wrapper flex flex-col items-center w-full pt-[8%] md:pt-0"
          style={{ maxWidth: '3000px', overflow: 'visible' }}
        >
          <!-- Doug and Karrie Image -->
          <div
            class="relative pointer-events-none z-[1]"
            style={{
              width: 'clamp(400px, 47.37vw, 900px)',
              maxWidth: '95vw',
              aspectRatio: '900 / 500',
              maxHeight: '50dvh',
              overflow: 'visible',
            }}
          >
            <div
              class="hero-3d-backdrop absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%]"
              style={{
                background: 'radial-gradient(ellipse 60% 50% at center 45%, rgba(100,80,150,0.15) 0%, rgba(50,40,80,0.1) 40%, transparent 70%)',
                filter: 'blur(40px)',
              }}
            />
            <img
              src="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop"
              srcset="
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/mobile 375w,
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/tablet 768w,
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop 1280w
              "
              sizes="(max-width: 480px) 375px, (max-width: 768px) 768px, 1280px"
              alt="Doug and Karrie - Co-founders of Smart Agent Alliance"
              width="900"
              height="500"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="hero-3d-image profile-image w-full h-full object-contain"
              style={{
                maskImage: 'linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 70%, rgba(0,0,0,0.9) 80%, rgba(0,0,0,0.6) 88%, rgba(0,0,0,0.3) 94%, transparent 100%)',
                WebkitMaskImage: 'linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 70%, rgba(0,0,0,0.9) 80%, rgba(0,0,0,0.6) 88%, rgba(0,0,0,0.3) 94%, transparent 100%)',
              }}
            />
          </div>

          <!-- H1, Tagline, and CTA -->
          <div
            class="w-full px-4 sm:px-8 md:px-12 text-center pointer-events-auto z-[2]"
            style={{
              maxWidth: '3000px',
              marginTop: 'calc(min(clamp(400px, 47.37vw, 900px) / 7.2, 12.5dvh) * -1)',
            }}
          >
            <div style={{ perspective: '1000px' }} class="relative">
              <div class="relative z-10">
                <H1 client:only="react" id="hero-heading" style={{ marginBottom: '3px' }}>
                  SMART AGENT ALLIANCE
                </H1>
                <Tagline client:only="react" className="hero-tagline-mobile-spacing" style={{ marginBottom: '0.25rem' }}>
                  For Agents Who Want More
                </Tagline>
                <p class="text-body opacity-90">
                  Everything you need to build a real estate business with lasting income.
                </p>
              </div>
            </div>

            <div class="hero-cta-buttons flex justify-center items-center" style={{ marginTop: '14px' }}>
              <JoinAllianceCTA client:idle>JOIN THE ALLIANCE</JoinAllianceCTA>
            </div>
          </div>
        </div>

        <!-- Counter Animation - Hydrates after initial render -->
        <CounterAnimation client:idle />
      </section>
    </div>

    <!-- Below-fold sections (lazy-loaded when visible) -->
    <HomepageSections client:visible />
  </main>
</BaseLayout>
