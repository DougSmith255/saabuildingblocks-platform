---
/**
 * Book a Call - Custom booking widget for GoHighLevel calendar.
 *
 * Hero is static. CustomBookingWidget is a client:load island
 * (needs interactivity immediately for the calendar).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import H1 from '@saa/shared/components/saa/headings/H1';
import Tagline from '@saa/shared/components/saa/headings/Tagline';
import CustomBookingWidget from '@public-site/app/book-a-call/components/CustomBookingWidget';
---

<BaseLayout
  title="Book a Call | Smart Agent Alliance"
  description="Schedule a one-on-one with our team to see if SAA is the right fit for you."
>
  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative min-h-[50dvh] flex items-center justify-center px-4 sm:px-8 md:px-12 pt-[150px] pb-16 md:pb-20">
      <div class="max-w-[1900px] mx-auto w-full text-center relative z-10">
        <div class="relative z-10">
          <H1 client:load>BOOK A CALL</H1>
          <Tagline client:load className="mt-4" style={{ maxWidth: '70vw', margin: '1rem auto 0' }}>
            Schedule a one-on-one with our team to see if SAA is the right fit for you.
          </Tagline>
        </div>
      </div>
    </section>

    <!-- Booking Widget Section -->
    <section class="relative pb-12 md:pb-20 px-4 sm:px-8 md:px-12" style={{ marginTop: '-2rem' }}>
      <div class="max-w-[1400px] mx-auto">
        <CustomBookingWidget client:load />
      </div>
    </section>
  </main>
</BaseLayout>
