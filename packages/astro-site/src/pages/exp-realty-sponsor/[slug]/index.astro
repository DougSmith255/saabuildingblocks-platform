---
/**
 * Dynamic exp-realty-sponsor blog posts: /exp-realty-sponsor/[slug]/
 * These are standalone category posts that live outside /blog/.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostIsland from '../../../islands/blog-post';
import { getAllBlogPosts, findPostBySlug, getRelatedPosts } from '../../../lib/blog-data';
import { cleanExcerpt } from '@public-site/lib/wordpress/fallbacks';
import { extractFAQs, generateFAQSchema, stripFAQSection } from '@public-site/lib/faq-utils';
import { extractTables, generateTableSchemas } from '@public-site/lib/table-utils';
import { buildBlogPostingSchema, buildVideoSchema } from '@public-site/lib/blog-schema';
import { getPostUrl } from '@public-site/lib/blog-post-urls';
import { buildBreadcrumbSchema } from '../../../lib/breadcrumb-schema';

export function getStaticPaths() {
  const posts = getAllBlogPosts();

  return posts
    .filter((post) => post.customUri?.startsWith('exp-realty-sponsor/'))
    .map((post) => ({
      params: { slug: post.customUri!.split('/').pop()! },
      props: { postSlug: post.customUri!.split('/').pop()! },
    }));
}

const { postSlug } = Astro.props;
const { slug } = Astro.params;
const posts = getAllBlogPosts();
const post = findPostBySlug(posts, postSlug);

if (!post) {
  return Astro.redirect('/404');
}

const category = post.categories[0] || 'uncategorized';
const relatedPosts = getRelatedPosts(posts, post);

const seoTitle = post.metaTitle || post.title;
const description = post.metaDescription || cleanExcerpt(post.excerpt, 160);
const ogImage = post.featuredImage?.url || '/og-image.jpg';

const postUrl = getPostUrl(post);
const faqs = extractFAQs(post.content);
const faqSchema = generateFAQSchema(faqs);
const tables = extractTables(post.content);
const tableSchemas = generateTableSchemas(tables, post.title);
const strippedContent = faqs.length > 0 ? stripFAQSection(post.content) : post.content;
const postForTemplate = { ...post, content: strippedContent };
const blogPostingSchema = buildBlogPostingSchema(post, postUrl);
const videoSchema = buildVideoSchema(post);
const breadcrumbSchema = buildBreadcrumbSchema(category, post.title);
---

<BaseLayout
  title={`${seoTitle} | Smart Agent Alliance`}
  description={description}
  canonical={`/exp-realty-sponsor/${slug}/`}
  ogImage={ogImage}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  {videoSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(videoSchema)} />}
  {faqSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {tableSchemas?.map(schema => <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <BlogPostIsland
    client:load
    post={postForTemplate}
    category={category}
    relatedPosts={relatedPosts}
    faqs={faqs}
  />
</BaseLayout>
