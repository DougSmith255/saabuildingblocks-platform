---
/**
 * eXp Realty Sponsor - Team Value Page
 *
 * Hero rendered as static HTML. Below-fold SponsorSections
 * loaded as a single React island (3333-line interactive component).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import H1 from '@saa/shared/components/saa/headings/H1';
import Tagline from '@saa/shared/components/saa/headings/Tagline';
import { CounterAnimation } from '@public-site/app/components/CounterAnimation';
import SponsorSections from '@public-site/app/exp-realty-sponsor/components/SponsorSections';
---

<BaseLayout
  title="eXp Realty Sponsor | Smart Agent Alliance"
  description="Premium tools, real training, and zero cost. Smart Agent Alliance delivers systems, income infrastructure, and community to independent eXp Realty agents."
>
  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative">
      <section class="relative min-h-[100dvh] flex items-center justify-center px-4 sm:px-8 md:px-12 py-24 md:py-32">
        <!-- Agent Counter (Desktop) - CSS handles visibility -->
        <style>
          .agent-counter-wrapper { opacity: 1; }
          .tagline-counter-suffix { display: none !important; }
          @media (max-width: 1499px) {
            .agent-counter-wrapper { display: none !important; }
            .tagline-counter-suffix { display: inline-flex !important; }
          }
        </style>
        <div
          class="agent-counter-wrapper absolute z-50 left-2 lg:left-auto lg:right-8"
          style={{ top: '130px' }}
        >
          <span style={{
            display: 'inline-flex',
            alignItems: 'center',
            gap: '0.25em',
            fontSize: 'clamp(1.75rem, 2.625vw, 2.1875rem)',
          }}>
            <span
              class="counter-numbers-mobile"
              style={{
                display: 'inline',
                color: '#e5e4dd',
                fontFamily: 'var(--font-synonym), monospace',
                fontWeight: '300',
                fontSize: 'calc(1em + 10px)',
                textShadow: 'none',
              }}
            >
              <span class="counter-digit">4</span>
              <span class="counter-digit">0</span>
              <span class="counter-digit">0</span>
              <span class="counter-digit">0</span>
              <span>+</span>
            </span>
            <span style={{
              color: '#e5e4dd',
              fontFamily: 'var(--font-taskor), sans-serif',
              fontFeatureSettings: '"ss01" 1',
              textTransform: 'uppercase',
              letterSpacing: '0.05em',
              transform: 'perspective(800px) rotateX(8deg)',
              display: 'inline-block',
              position: 'relative',
              fontWeight: '700',
              textShadow: '0.005em 0.007em 0 #dddcd5, 0.010em 0.015em 0 #d5d4cb, 0.015em 0.025em 0 #cccbc2, 0.019em 0.035em 0 #c2c1b8, 0.023em 0.045em 0 #b8b7ae, 0.027em 0.055em 0 #abaa9f, 0.031em 0.065em 0 #a09f94, 0.034em 0.073em 0 #96958a, 0.037em 0.080em 0 #8d8c80, 0.040em 0.088em 0 #7a7970',
            }}>AGENTS</span>
          </span>
        </div>

        <!-- Background Wolf Pack Image -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-[1]">
          <div class="relative w-full min-w-[300px] max-w-[2000px] h-full">
            <img
              src="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/6dc6fe182a485b79-Smart-agent-alliance-and-the-wolf-pack.webp/desktop"
              srcset="
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/6dc6fe182a485b79-Smart-agent-alliance-and-the-wolf-pack.webp/mobile 640w,
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/6dc6fe182a485b79-Smart-agent-alliance-and-the-wolf-pack.webp/tablet 1024w,
                https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/6dc6fe182a485b79-Smart-agent-alliance-and-the-wolf-pack.webp/desktop 2000w
              "
              sizes="100vw"
              alt=""
              aria-hidden="true"
              loading="eager"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover"
              style={{
                objectPosition: 'center 55%',
                maskImage: 'radial-gradient(ellipse 55% 50% at center 55%, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 25%, rgba(0,0,0,0.3) 45%, rgba(0,0,0,0.15) 65%, transparent 85%)',
                WebkitMaskImage: 'radial-gradient(ellipse 55% 50% at center 55%, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 25%, rgba(0,0,0,0.3) 45%, rgba(0,0,0,0.15) 65%, transparent 85%)',
              }}
            />
          </div>
        </div>

        <!-- Hero Text -->
        <div class="max-w-[2500px] mx-auto w-full text-center relative z-10">
          <div class="relative z-10">
            <H1 client:load>Smart Agent Alliance</H1>
            <Tagline client:load className="mt-4" style={{ maxWidth: '95%', marginLeft: 'auto', marginRight: 'auto' }}>
              Premium Tools. Real Training. Zero Cost.
            </Tagline>
          </div>
        </div>

        <CounterAnimation client:idle />
      </section>
    </div>

    <!-- Below-fold sections -->
    <SponsorSections client:visible />
  </main>
</BaseLayout>
