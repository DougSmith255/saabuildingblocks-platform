---
import BaseLayout from '../../layouts/BaseLayout.astro';
import H1 from '@saa/shared/components/saa/headings/H1';
import H2 from '@saa/shared/components/saa/headings/H2';
import Tagline from '@saa/shared/components/saa/headings/Tagline';
import { GenericCard } from '@saa/shared/components/saa/cards/GenericCard';
import { GrainCard } from '@saa/shared/components/saa/cards/GrainCard';
import { CTAButton } from '../../components/react/CTAButton';
import { JoinAllianceCTA } from '../../components/react/JoinAllianceCTA';

const comparisons = [
  {
    title: "eXp vs Online Brokerages",
    description: "Compare eXp Realty to other cloud-based brokerages like Real, LPT Realty, and Fathom.",
    href: "/best-real-estate-brokerage/online/",
    highlight: "Cloud vs Cloud"
  },
  {
    title: "eXp vs Traditional Brokerages",
    description: "See how eXp stacks up against brick-and-mortar brokerages like Keller Williams, RE/MAX, and Coldwell Banker.",
    href: "/best-real-estate-brokerage/traditional/",
    highlight: "Cloud VS Traditional",
    tagline: "New School vs Old School"
  }
];

const whyCompare = [
  {
    title: "Commission Structure",
    description: "Understand how different splits, caps, and fees affect your take-home pay."
  },
  {
    title: "Technology & Tools",
    description: "Compare CRM systems, lead generation, and marketing tools included."
  },
  {
    title: "Passive Income",
    description: "Evaluate revenue share and stock programs for long-term wealth building."
  },
  {
    title: "Support & Training",
    description: "See what mentorship, training, and community support each brokerage offers."
  }
];
---

<BaseLayout
  title="Best Real Estate Brokerage Comparison"
  description="Compare eXp Realty to traditional and online brokerages. Commission splits, fees, technology, and passive income - all the numbers."
  ogTitle="Brokerage Comparison | Smart Agent Alliance"
>
  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative">
      <section class="relative min-h-[100dvh] flex items-center justify-center px-4 sm:px-8 md:px-12 py-24 md:py-32">
        <div class="max-w-[1900px] mx-auto w-full text-center relative z-10">
          <div class="relative z-10">
            <H1 client:load>KNOW THE NUMBERS</H1>
            <Tagline client:load className="mt-4">
              Facts over feelings
            </Tagline>
          </div>
        </div>
      </section>
    </div>

    <!-- Comparison Cards -->
    <section class="relative py-16 md:py-24 px-4 sm:px-8 md:px-12">
      <div class="max-w-[1900px] mx-auto">
        <div class="text-center mb-12">
          <H2 client:visible>Pick Your Battle</H2>
          <p class="text-body mt-4 max-w-2xl mx-auto">
            See how eXp stacks up against the competition.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {comparisons.map((comparison) => (
            <a href={comparison.href} class="block group">
              <GenericCard hover padding="lg" className="h-full">
                <div class="text-link font-medium mb-1" style={{ fontSize: 'var(--font-size-caption)' }}>{comparison.highlight}</div>
                {comparison.tagline && (
                  <div class="text-caption mb-3" style={{ color: 'var(--text-muted)' }}>{comparison.tagline}</div>
                )}
                <h3 class="text-h5 mb-3">{comparison.title}</h3>
                <p class="text-body mb-4">{comparison.description}</p>
                <span class="text-link group-hover:underline">View Comparison →</span>
              </GenericCard>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Compare Section -->
    <section class="relative py-16 md:py-24 px-4 sm:px-8 md:px-12">
      <div class="max-w-[1900px] mx-auto">
        <div class="text-center mb-12">
          <H2 client:visible>What Actually Matters</H2>
          <p class="text-body mt-4 max-w-2xl mx-auto">
            Your brokerage choice impacts your income for years. Focus on these.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {whyCompare.map((item) => (
            <GenericCard padding="md" className="h-full">
              <h3 class="text-h6 mb-2">{item.title}</h3>
              <p class="text-body">{item.description}</p>
            </GenericCard>
          ))}
        </div>
      </div>
    </section>

    <!-- eXp Highlights -->
    <section class="relative py-16 md:py-24 px-4 sm:px-8 md:px-12">
      <div class="max-w-[1900px] mx-auto">
        <div class="text-center mb-12">
          <H2 client:visible>The eXp Edge</H2>
          <p class="text-body mt-4 max-w-2xl mx-auto">
            The numbers speak for themselves.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 text-center items-stretch">
          <GrainCard padding="lg" className="h-full">
            <p class="text-h3 mb-2 stat-3d-text">100%</p>
            <p class="text-body">Commission After Cap</p>
            <p class="text-caption mt-1">Cap at just $16,000</p>
          </GrainCard>

          <GrainCard padding="lg" className="h-full">
            <p class="text-h3 mb-2 stat-3d-text">$85</p>
            <p class="text-body">Monthly Fee</p>
            <p class="text-caption mt-1">No desk or franchise fees</p>
          </GrainCard>

          <GrainCard padding="lg" className="h-full">
            <p class="text-h3 mb-2 stat-3d-text">4</p>
            <p class="text-body">Income Streams</p>
            <p class="text-caption mt-1">Commission, stock, rev share, referrals</p>
          </GrainCard>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-16 md:py-24 px-4 sm:px-8 md:px-12">
      <div class="max-w-[1900px] mx-auto text-center">
        <H2 client:visible>Ready to Make the Move?</H2>
        <p class="text-body mt-4 mb-8">
          Stop leaving money on the table. Join the Alliance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <JoinAllianceCTA client:idle />
          <CTAButton client:visible href="/about-exp-realty/">
            Learn About eXp
          </CTAButton>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
