---
/**
 * H2 - Pure CSS 3D Heading with 2 Stacked Backing Layers
 *
 * Astro port of @saa/shared/components/saa/headings/H2
 * Exact match to React production version.
 * 2 backing layers: bright/far + dark/near (bolder)
 * Zero JavaScript. Fully static HTML.
 *
 * Themes: default (grey), gold, blue, purple, emerald
 */
interface Props {
  class?: string;
  style?: Record<string, string>;
  theme?: 'default' | 'gold' | 'blue' | 'purple' | 'emerald';
}

const { class: className = '', style = {}, theme = 'default' } = Astro.props;

// ── Face text-shadow (extrusion depth) ───────────────────────────────

const FACE_SHADOW = [
  '0.003em 0.005em 0 #dddcd5',
  '0.006em 0.011em 0 #d5d4cb',
  '0.009em 0.017em 0 #cccbc2',
  '0.012em 0.023em 0 #c2c1b8',
  '0.015em 0.030em 0 #b8b7ae',
  '0.018em 0.037em 0 #abaa9f',
  '0.021em 0.044em 0 #a09f94',
  '0.024em 0.051em 0 #96958a',
  '0.027em 0.058em 0 #8d8c80',
  '0.030em 0.065em 0 #838277',
  '0.033em 0.070em 0 #7a7970',
].join(', ');

// ── Theme configs ────────────────────────────────────────────────────
// 2 backing layers: bright/far + dark/near (bolder)

interface BackingLayer { color: string; tx: string; ty: string; stroke: string; }
interface H2Config {
  rotateX: string; rotateY: string;
  shadow: { color: string; tx: string; ty: string; blur: string };
  layers: BackingLayer[];
  face: { color: string; tx: string; ty: string; textShadow: string };
}

const BASE = { rotateX: '8deg', rotateY: '-1.5deg' };

const CONFIGS: Record<string, H2Config> = {
  default: {
    ...BASE,
    shadow: { color: 'rgba(64, 64, 64, 0.4)', tx: '0.025em', ty: '0.07em', blur: '4px' },
    layers: [
      { color: '#444444', tx: '0.022em', ty: '0.065em', stroke: '0.10em' },
      { color: '#1a1a1a', tx: '0em', ty: '0em', stroke: '0.16em' },
    ],
    face: { color: '#e5e4dd', tx: '-0.025em', ty: '-0.055em', textShadow: FACE_SHADOW },
  },
  gold: {
    ...BASE,
    shadow: { color: 'rgba(184, 150, 10, 0.4)', tx: '0.025em', ty: '0.07em', blur: '4px' },
    layers: [
      { color: '#e6ac00', tx: '0.022em', ty: '0.065em', stroke: '0.10em' },
      { color: '#191818', tx: '0em', ty: '0em', stroke: '0.16em' },
    ],
    face: { color: '#e8d4a0', tx: '-0.025em', ty: '-0.055em', textShadow: FACE_SHADOW },
  },
  blue: {
    ...BASE,
    shadow: { color: 'rgba(10, 120, 152, 0.4)', tx: '0.025em', ty: '0.07em', blur: '4px' },
    layers: [
      { color: '#00bfff', tx: '0.022em', ty: '0.065em', stroke: '0.10em' },
      { color: '#181920', tx: '0em', ty: '0em', stroke: '0.16em' },
    ],
    face: { color: '#b0d4e8', tx: '-0.025em', ty: '-0.055em', textShadow: FACE_SHADOW },
  },
  purple: {
    ...BASE,
    shadow: { color: 'rgba(96, 48, 160, 0.4)', tx: '0.025em', ty: '0.07em', blur: '4px' },
    layers: [
      { color: '#9933ff', tx: '0.022em', ty: '0.065em', stroke: '0.10em' },
      { color: '#1a1020', tx: '0em', ty: '0em', stroke: '0.16em' },
    ],
    face: { color: '#d4b0e8', tx: '-0.025em', ty: '-0.055em', textShadow: FACE_SHADOW },
  },
  emerald: {
    ...BASE,
    shadow: { color: 'rgba(10, 152, 104, 0.4)', tx: '0.025em', ty: '0.07em', blur: '4px' },
    layers: [
      { color: '#10b981', tx: '0.022em', ty: '0.065em', stroke: '0.10em' },
      { color: '#101a18', tx: '0em', ty: '0em', stroke: '0.16em' },
    ],
    face: { color: '#a0e8c4', tx: '-0.025em', ty: '-0.055em', textShadow: FACE_SHADOW },
  },
};

const config = CONFIGS[theme] || CONFIGS.default;
const textAlign = style.textAlign || 'center';

const persp = (tx: string, ty: string) =>
  `perspective(800px) rotateX(${config.rotateX}) rotateY(${config.rotateY}) translate(${tx}, ${ty})`;

const layerBase = `position: absolute; top: 0; left: 0; right: 0; pointer-events: none; text-align: ${textAlign}; line-height: 1.1; margin-left: ${textAlign === 'left' ? '0' : 'auto'}; margin-right: ${textAlign === 'right' ? '0' : 'auto'}; max-width: ${style.maxWidth || '95%'};`;

const layerStyle = (layer: BackingLayer) =>
  `${layerBase} color: ${layer.color}; -webkit-text-stroke: ${layer.stroke} ${layer.color}; -webkit-text-fill-color: ${layer.color}; paint-order: stroke fill; text-shadow: none; transform: ${persp(layer.tx, layer.ty)};`;

const shadowStyle = `${layerBase} margin-top: 0; margin-bottom: 0; color: ${config.shadow.color}; text-shadow: none; transform: ${persp(config.shadow.tx, config.shadow.ty)}; filter: blur(${config.shadow.blur});`;

const faceStyle = {
  textAlign,
  marginTop: '0',
  marginLeft: textAlign === 'left' ? '0' : 'auto',
  marginRight: textAlign === 'right' ? '0' : 'auto',
  marginBottom: '0',
  maxWidth: style.maxWidth || '95%',
  color: config.face.color,
  textShadow: config.face.textShadow,
  transform: persp(config.face.tx, config.face.ty),
  lineHeight: '1.1',
  position: 'relative',
  overflow: 'visible',
  ...style,
};

const faceStyleString = Object.entries(faceStyle).map(([k, v]) => {
  const prop = k.replace(/([A-Z])/g, '-$1').toLowerCase();
  return `${prop}: ${v}`;
}).join('; ');
---

<div style={`position: relative; display: inline-block; width: 100%; overflow: visible; font-feature-settings: 'ss02' 1; text-align: ${textAlign};`}>
  {/* Backing layers */}
  <div aria-hidden="true" style="user-select: none;">
    {/* Shadow */}
    <div class:list={['text-h2', className]} style={shadowStyle}>
      <slot />
    </div>
    {/* 2 stroked layers */}
    {config.layers.map((layer) => (
      <div class:list={['text-h2', className]} style={layerStyle(layer)}>
        <slot />
      </div>
    ))}
  </div>

  {/* Face */}
  <h2
    class:list={['text-h2', className]}
    style={faceStyleString}
  >
    <slot />
  </h2>
</div>
