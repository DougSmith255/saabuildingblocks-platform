---
/**
 * GlassPanel - Tinted glass background with texture overlay
 *
 * Astro port of @saa/shared/components/saa/backgrounds/GlassPanel
 * Pure CSS, zero JavaScript.
 *
 * Variants: champagne, marigoldCrosshatch, marigoldNoise, emerald, expBlue, expBlueCrosshatch, tealCrosshatch
 */
export type GlassPanelVariant = 'champagne' | 'marigoldCrosshatch' | 'marigoldNoise' | 'emerald' | 'expBlue' | 'expBlueCrosshatch' | 'tealCrosshatch';

interface Props {
  variant: GlassPanelVariant;
  class?: string;
  rounded?: 'md' | 'lg' | 'xl' | '2xl' | '3xl' | 'full';
  opacity?: number;
  noBlur?: boolean;
}

const { variant, class: className = '', rounded = '3xl', opacity, noBlur } = Astro.props;

const VARIANTS = {
  champagne: { r: 247, g: 231, b: 206, colorOpacity: 0.05, borderOpacity: 0.08, texture: 'dots', textureOpacity: 0.04, noiseFrequency: 1.5 },
  marigoldCrosshatch: { r: 255, g: 190, b: 0, colorOpacity: 0.04, borderOpacity: 0.11, texture: 'crosshatch', textureOpacity: 0.03, noiseFrequency: 0.8 },
  marigoldNoise: { r: 255, g: 190, b: 0, colorOpacity: 0.04, borderOpacity: 0.11, texture: 'noise', textureOpacity: 0.06, noiseFrequency: 0.9 },
  emerald: { r: 16, g: 185, b: 129, colorOpacity: 0.12, borderOpacity: 0.2, texture: 'hlines', textureOpacity: 0.04, noiseFrequency: 1.0 },
  expBlue: { r: 0, g: 102, b: 170, colorOpacity: 0.10, borderOpacity: 0.18, texture: 'hlines', textureOpacity: 0.035, noiseFrequency: 1.0 },
  expBlueCrosshatch: { r: 0, g: 102, b: 170, colorOpacity: 0.06, borderOpacity: 0.14, texture: 'crosshatch', textureOpacity: 0.03, noiseFrequency: 0.8 },
  tealCrosshatch: { r: 40, g: 140, b: 160, colorOpacity: 0.04, borderOpacity: 0.11, texture: 'crosshatch', textureOpacity: 0.03, noiseFrequency: 0.8 },
} as const;

const ROUNDED_CLASSES: Record<string, string> = {
  md: 'rounded-md', lg: 'rounded-lg', xl: 'rounded-xl',
  '2xl': 'rounded-2xl', '3xl': 'rounded-3xl', full: 'rounded-full',
};

const config = VARIANTS[variant];
const { r, g, b } = config;
const effectiveOpacity = opacity !== undefined ? opacity : config.colorOpacity;
const roundedClass = ROUNDED_CLASSES[rounded];
const isEmerald = variant === 'emerald';
const isExpBlue = variant === 'expBlue';

// Background gradient
const bgGradient = `linear-gradient(180deg, rgba(${r},${g},${b},${effectiveOpacity * 0.8}) 0%, rgba(${r},${g},${b},${effectiveOpacity}) 50%, rgba(${r},${g},${b},${effectiveOpacity * 0.8}) 100%)`;

// Box shadow (3D plate appearance)
const boxShadow = `0 8px 32px rgba(0,0,0,0.4), 0 4px 12px rgba(0,0,0,0.25), inset 0 1px 0 0 rgba(255,255,255,0.35), inset 0 2px 4px 0 rgba(255,255,255,0.2), inset 0 8px 20px -8px rgba(${r},${g},${b},0.3), inset 0 20px 40px -20px rgba(255,255,255,0.15), inset 0 -1px 0 0 rgba(0,0,0,0.7), inset 0 -2px 6px 0 rgba(0,0,0,0.5), inset 0 -10px 25px -8px rgba(0,0,0,0.6), inset 0 -25px 50px -20px rgba(0,0,0,0.45)`;

// Texture styles
function getTextureStyle(texture: string, texOpacity: number, frequency: number): string {
  switch (texture) {
    case 'crosshatch':
      return `background-image: repeating-linear-gradient(45deg, rgba(255,255,255,${texOpacity}) 0px, transparent 1px, transparent 6px), repeating-linear-gradient(-45deg, rgba(255,255,255,${texOpacity}) 0px, transparent 1px, transparent 6px); background-size: 16px 16px;`;
    case 'dots':
      return `background-image: radial-gradient(circle, rgba(255,255,255,${texOpacity * 2}) 1px, transparent 1px); background-size: ${Math.round(12 / frequency)}px ${Math.round(12 / frequency)}px;`;
    case 'hlines':
      return `background-image: repeating-linear-gradient(180deg, rgba(255,255,255,${texOpacity}) 0px, transparent 1px, transparent 3px); background-size: 100% 3px; background-repeat: repeat;`;
    case 'noise':
    default:
      return `background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='${frequency}' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E"); opacity: ${texOpacity}; mix-blend-mode: overlay;`;
  }
}

const textureStyleStr = getTextureStyle(config.texture, config.textureOpacity, config.noiseFrequency);
const blurStyle = noBlur ? '' : 'backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);';
---

{(isEmerald || isExpBlue) && (
  <style>
    @keyframes vignetteGlow {
      0%, 100% { box-shadow: inset 0 0 40px 15px rgba(var(--vg-r), var(--vg-g), var(--vg-b), 0.25); }
      50% { box-shadow: inset 0 0 60px 25px rgba(var(--vg-r), var(--vg-g), var(--vg-b), 0.4); }
    }
  </style>
)}

<div
  class:list={[`relative overflow-hidden ${roundedClass}`, className]}
  style={`background: ${bgGradient}; box-shadow: ${boxShadow}; ${blurStyle}`}
>
  {/* Vignette glow for emerald/expBlue */}
  {isEmerald && (
    <div
      class={`absolute inset-0 pointer-events-none z-[3] ${roundedClass}`}
      style={`--vg-r: 16; --vg-g: 185; --vg-b: 129; animation: vignetteGlow 4s ease-in-out infinite;`}
    />
  )}
  {isExpBlue && (
    <div
      class={`absolute inset-0 pointer-events-none z-[3] ${roundedClass}`}
      style={`--vg-r: 0; --vg-g: 102; --vg-b: 170; animation: vignetteGlow 4s ease-in-out infinite;`}
    />
  )}

  {/* Texture overlay */}
  <div class={`absolute inset-0 pointer-events-none z-[1] ${roundedClass}`} style={textureStyleStr} />

  {/* Bottom edge darkening for emerald/expBlue */}
  {(isEmerald || isExpBlue) && (
    <div
      class={`absolute bottom-0 left-0 right-0 pointer-events-none z-[2] ${roundedClass}`}
      style="height: 80px; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.3) 30%, transparent 100%); border-bottom-left-radius: inherit; border-bottom-right-radius: inherit;"
    />
  )}

  {/* Content */}
  <div class="relative z-10">
    <slot />
  </div>
</div>
