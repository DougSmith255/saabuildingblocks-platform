---
/**
 * DevToolbar - Floating dev tools bar on the left side.
 * Only rendered when import.meta.env.DEV is true (Astro dev server).
 * Provides contextual actions like "Edit in WordPress" for blog pages.
 *
 * Props:
 *   wpPostId - WordPress post ID for blog pages (shows edit button)
 */
interface Props {
  wpPostId?: number;
}

const { wpPostId } = Astro.props;
const wpEditUrl = wpPostId ? `https://wp.saabuildingblocks.com/wp-admin/post.php?post=${wpPostId}&action=edit` : null;
const currentPath = Astro.url.pathname;
const prodUrl = `https://smartagentalliance.com${currentPath}`;
const plausibleUrl = `https://plausible.saabuildingblocks.com/smartagentalliance.com?page=${encodeURIComponent(currentPath)}`;
const psiUrl = `https://pagespeed.web.dev/analysis?url=${encodeURIComponent(prodUrl)}`;

// GitHub build status (fetched server-side)
const ghToken = import.meta.env.GITHUB_TOKEN || '';
const ghRepo = 'DougSmith255/saabuildingblocks-platform';
let workflows: Array<{ name: string; status: string; conclusion: string | null; url: string; created: string }> = [];
let ghError = false;

if (ghToken) {
  try {
    const res = await fetch(`https://api.github.com/repos/${ghRepo}/actions/runs?per_page=5&branch=main`, {
      headers: { Authorization: `token ${ghToken}`, Accept: 'application/vnd.github.v3+json' },
    });
    if (res.ok) {
      const data = await res.json();
      // Get latest run per workflow name
      const seen = new Set<string>();
      for (const run of data.workflow_runs || []) {
        if (!seen.has(run.name)) {
          seen.add(run.name);
          workflows.push({
            name: run.name,
            status: run.status,
            conclusion: run.conclusion,
            url: run.html_url,
            created: run.created_at,
          });
        }
      }
    } else {
      ghError = true;
    }
  } catch {
    ghError = true;
  }
}

// Determine aggregate status
function getAggStatus(wfs: typeof workflows) {
  if (wfs.length === 0) return 'unknown';
  if (wfs.some(w => w.status === 'in_progress' || w.status === 'queued')) return 'running';
  if (wfs.some(w => w.conclusion === 'failure')) return 'failure';
  if (wfs.every(w => w.conclusion === 'success')) return 'success';
  return 'unknown';
}

const aggStatus = ghError ? 'error' : getAggStatus(workflows);
const statusColors: Record<string, string> = {
  success: '#00ff88',
  failure: '#ff4444',
  running: '#ffd700',
  error: '#888',
  unknown: '#888',
};
const statusColor = statusColors[aggStatus] || '#888';
---

<div id="dev-toolbar" style="position:fixed; left:0; top:50%; transform:translateY(-50%); z-index:99999; display:flex; flex-direction:column; gap:6px; padding:8px 6px; background:rgba(0,0,0,0.85); border:1px solid rgba(255,215,0,0.3); border-left:none; border-radius:0 10px 10px 0; backdrop-filter:blur(8px); font-family:system-ui,-apple-system,sans-serif;">

  <!-- Toggle collapse -->
  <button id="dev-toolbar-toggle" title="Collapse toolbar" style="background:none; border:none; cursor:pointer; padding:2px; display:flex; align-items:center; justify-content:center;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffd700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>

  <div id="dev-toolbar-items" style="display:flex; flex-direction:column; gap:6px;">

    <!-- WordPress Edit (blog pages only) -->
    {wpEditUrl && (
      <a href={wpEditUrl} target="_blank" rel="noopener" title={`Edit WP Post #${wpPostId}`} class="dtb dtb-gold">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffd700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      </a>
    )}

    <!-- Master Controller -->
    <a href="https://saabuildingblocks.com/master-controller" target="_blank" rel="noopener" title="Master Controller" class="dtb dtb-blue">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00bfff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
    </a>

    <!-- View Production -->
    <a href={prodUrl} target="_blank" rel="noopener" title="View on Production" class="dtb dtb-green">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
    </a>

    <!-- Plausible Analytics -->
    <a href={plausibleUrl} target="_blank" rel="noopener" title="Plausible Analytics" class="dtb dtb-purple">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="20" x2="18" y2="10"/>
        <line x1="12" y1="20" x2="12" y2="4"/>
        <line x1="6" y1="20" x2="6" y2="14"/>
      </svg>
    </a>

    <!-- PageSpeed Insights -->
    <a href={psiUrl} target="_blank" rel="noopener" title="PageSpeed Insights" class="dtb dtb-orange">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
    </a>

    <!-- GitHub Build Status -->
    <button id="dev-toolbar-gh" title="GitHub Build Status" class="dtb" style={`background:rgba(${aggStatus === 'success' ? '0,255,136' : aggStatus === 'failure' ? '255,68,68' : aggStatus === 'running' ? '255,215,0' : '255,255,255'},0.15); border:1px solid rgba(${aggStatus === 'success' ? '0,255,136' : aggStatus === 'failure' ? '255,68,68' : aggStatus === 'running' ? '255,215,0' : '255,255,255'},0.3);`}
      data-gh-token={ghToken}
      data-gh-repo={ghRepo}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={statusColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
      </svg>
      <!-- Status dot -->
      <span id="gh-status-dot" style={`position:absolute; top:2px; right:2px; width:7px; height:7px; border-radius:50%; background:${statusColor}; border:1px solid rgba(0,0,0,0.5);`}></span>
    </button>

    <!-- Copy Path -->
    <button id="dev-toolbar-copy" title="Copy page path" class="dtb dtb-white">
      <svg id="dev-copy-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e5e4dd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <svg id="dev-check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </button>

    <!-- Page Info -->
    <button id="dev-toolbar-info" title="Page Info" class="dtb dtb-white">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e5e4dd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
    </button>
  </div>
</div>

<!-- Page info tooltip -->
<div id="dev-toolbar-tooltip" style="display:none; position:fixed; left:50px; top:50%; transform:translateY(-50%); z-index:99998; background:rgba(0,0,0,0.92); border:1px solid rgba(255,215,0,0.3); border-radius:8px; padding:12px 16px; font-family:monospace; font-size:12px; color:#e5e4dd; max-width:400px; backdrop-filter:blur(8px);">
  <div style="margin-bottom:6px; color:#ffd700; font-weight:bold; font-family:system-ui;">Page Info</div>
  <div style="line-height:1.8;">
    <div><span style="color:#888;">Path:</span> {currentPath}</div>
    {wpPostId && <div><span style="color:#888;">WP Post ID:</span> {wpPostId}</div>}
    <div><span style="color:#888;">Mode:</span> <span style="color:#00ff88;">DEV</span></div>
  </div>
</div>

<!-- GitHub build status tooltip -->
<div id="dev-gh-tooltip" style="display:none; position:fixed; left:50px; top:50%; transform:translateY(-50%); z-index:99998; background:rgba(0,0,0,0.92); border:1px solid rgba(255,215,0,0.3); border-radius:8px; padding:12px 16px; font-family:monospace; font-size:12px; color:#e5e4dd; max-width:420px; backdrop-filter:blur(8px);">
  <div style="margin-bottom:8px; display:flex; align-items:center; justify-content:space-between;">
    <span style="color:#ffd700; font-weight:bold; font-family:system-ui;">GitHub Build Status</span>
    <span id="gh-last-updated" style="color:#666; font-size:10px;"></span>
  </div>
  <div id="gh-workflow-list" style="line-height:2;">
    {workflows.length === 0 && !ghError && <div style="color:#888;">No workflow data available</div>}
    {ghError && <div style="color:#ff4444;">Failed to fetch GitHub status</div>}
    {workflows.map(wf => {
      const wfColor = wf.status === 'in_progress' || wf.status === 'queued' ? '#ffd700' : wf.conclusion === 'success' ? '#00ff88' : wf.conclusion === 'failure' ? '#ff4444' : '#888';
      const wfLabel = wf.status === 'in_progress' ? 'running' : wf.status === 'queued' ? 'queued' : wf.conclusion || 'unknown';
      const timeAgo = wf.created;
      return (
        <div style="display:flex; align-items:center; gap:8px;">
          <span style={`display:inline-block; width:8px; height:8px; border-radius:50%; background:${wfColor}; flex-shrink:0;`}></span>
          <a href={wf.url} target="_blank" rel="noopener" style={`color:${wfColor}; text-decoration:none; flex:1;`}>{wf.name}</a>
          <span style="color:#666; font-size:10px; flex-shrink:0;">{wfLabel}</span>
        </div>
      );
    })}
  </div>
  <div style="margin-top:8px; border-top:1px solid rgba(255,255,255,0.1); padding-top:6px;">
    <a href={`https://github.com/${ghRepo}/actions`} target="_blank" rel="noopener" style="color:#00bfff; text-decoration:none; font-size:11px; font-family:system-ui;">View all workflows &rarr;</a>
  </div>
</div>

<style is:inline>
.dtb {
  position: relative;
  border-radius: 6px;
  padding: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s, transform 0.15s;
}
.dtb:hover { transform: scale(1.1); }
.dtb:active { transform: scale(0.95); }
.dtb-gold { background: rgba(255,215,0,0.15); border: 1px solid rgba(255,215,0,0.3); }
.dtb-gold:hover { background: rgba(255,215,0,0.3); }
.dtb-blue { background: rgba(0,191,255,0.15); border: 1px solid rgba(0,191,255,0.3); }
.dtb-blue:hover { background: rgba(0,191,255,0.3); }
.dtb-green { background: rgba(0,255,136,0.15); border: 1px solid rgba(0,255,136,0.3); }
.dtb-green:hover { background: rgba(0,255,136,0.3); }
.dtb-purple { background: rgba(167,139,250,0.15); border: 1px solid rgba(167,139,250,0.3); }
.dtb-purple:hover { background: rgba(167,139,250,0.3); }
.dtb-orange { background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3); }
.dtb-orange:hover { background: rgba(249,115,22,0.3); }
.dtb-white { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); }
.dtb-white:hover { background: rgba(255,255,255,0.2); }
@keyframes gh-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.gh-running #gh-status-dot { animation: gh-pulse 2s ease-in-out infinite; }
</style>

<script is:inline>
(function() {
  var items = document.getElementById('dev-toolbar-items');
  var toggle = document.getElementById('dev-toolbar-toggle');
  var infoBtn = document.getElementById('dev-toolbar-info');
  var tooltip = document.getElementById('dev-toolbar-tooltip');
  var copyBtn = document.getElementById('dev-toolbar-copy');
  var copyIcon = document.getElementById('dev-copy-icon');
  var checkIcon = document.getElementById('dev-check-icon');
  var ghBtn = document.getElementById('dev-toolbar-gh');
  var ghTooltip = document.getElementById('dev-gh-tooltip');
  var ghList = document.getElementById('gh-workflow-list');
  var ghDot = document.getElementById('gh-status-dot');
  var ghUpdated = document.getElementById('gh-last-updated');
  var collapsed = false;

  // Collapse toggle
  if (toggle) toggle.addEventListener('click', function() {
    collapsed = !collapsed;
    items.style.display = collapsed ? 'none' : 'flex';
    toggle.querySelector('svg').style.transform = collapsed ? 'rotate(180deg)' : '';
    toggle.title = collapsed ? 'Expand toolbar' : 'Collapse toolbar';
  });

  // Page info tooltip
  if (infoBtn && tooltip) {
    var infoShowing = false;
    infoBtn.addEventListener('click', function() {
      infoShowing = !infoShowing;
      tooltip.style.display = infoShowing ? 'block' : 'none';
      // Close GH tooltip if open
      if (infoShowing && ghTooltip) ghTooltip.style.display = 'none';
    });
  }

  // Copy path
  if (copyBtn) copyBtn.addEventListener('click', function() {
    navigator.clipboard.writeText(location.pathname).then(function() {
      copyIcon.style.display = 'none';
      checkIcon.style.display = 'block';
      setTimeout(function() {
        copyIcon.style.display = 'block';
        checkIcon.style.display = 'none';
      }, 1500);
    });
  });

  // GitHub build status
  var ghShowing = false;
  var ghToken = ghBtn ? ghBtn.getAttribute('data-gh-token') : '';
  var ghRepo = ghBtn ? ghBtn.getAttribute('data-gh-repo') : '';

  function timeAgo(dateStr) {
    var diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
    if (diff < 60) return diff + 's ago';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function statusColor(status, conclusion) {
    if (status === 'in_progress' || status === 'queued') return '#ffd700';
    if (conclusion === 'success') return '#00ff88';
    if (conclusion === 'failure') return '#ff4444';
    return '#888';
  }

  function statusLabel(status, conclusion) {
    if (status === 'in_progress') return 'running';
    if (status === 'queued') return 'queued';
    return conclusion || 'unknown';
  }

  function updateGHStatus() {
    if (!ghToken || !ghRepo) return;
    fetch('https://api.github.com/repos/' + ghRepo + '/actions/runs?per_page=5&branch=main', {
      headers: { Authorization: 'token ' + ghToken, Accept: 'application/vnd.github.v3+json' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var runs = data.workflow_runs || [];
      var seen = {};
      var wfs = [];
      for (var i = 0; i < runs.length; i++) {
        if (!seen[runs[i].name]) {
          seen[runs[i].name] = true;
          wfs.push(runs[i]);
        }
      }

      // Update dot color
      var hasRunning = wfs.some(function(w) { return w.status === 'in_progress' || w.status === 'queued'; });
      var hasFailed = wfs.some(function(w) { return w.conclusion === 'failure'; });
      var allSuccess = wfs.every(function(w) { return w.conclusion === 'success'; });
      var dotColor = hasRunning ? '#ffd700' : hasFailed ? '#ff4444' : allSuccess ? '#00ff88' : '#888';

      if (ghDot) ghDot.style.background = dotColor;
      if (ghBtn) {
        var rgb = hasRunning ? '255,215,0' : hasFailed ? '255,68,68' : allSuccess ? '0,255,136' : '255,255,255';
        ghBtn.style.background = 'rgba(' + rgb + ',0.15)';
        ghBtn.style.borderColor = 'rgba(' + rgb + ',0.3)';
        ghBtn.querySelector('svg').setAttribute('stroke', dotColor);
        if (hasRunning) ghBtn.classList.add('gh-running');
        else ghBtn.classList.remove('gh-running');
      }

      // Update tooltip content
      if (ghList) {
        var html = '';
        for (var j = 0; j < wfs.length; j++) {
          var wf = wfs[j];
          var c = statusColor(wf.status, wf.conclusion);
          var label = statusLabel(wf.status, wf.conclusion);
          html += '<div style="display:flex;align-items:center;gap:8px;">' +
            '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:' + c + ';flex-shrink:0;"></span>' +
            '<a href="' + wf.html_url + '" target="_blank" rel="noopener" style="color:' + c + ';text-decoration:none;flex:1;">' + wf.name + '</a>' +
            '<span style="color:#666;font-size:10px;flex-shrink:0;">' + label + ' - ' + timeAgo(wf.created_at) + '</span>' +
            '</div>';
        }
        if (wfs.length === 0) html = '<div style="color:#888;">No workflow data</div>';
        ghList.innerHTML = html;
      }
      if (ghUpdated) ghUpdated.textContent = 'Updated ' + new Date().toLocaleTimeString();
    })
    .catch(function() {
      if (ghDot) ghDot.style.background = '#888';
    });
  }

  if (ghBtn && ghTooltip) {
    ghBtn.addEventListener('click', function() {
      ghShowing = !ghShowing;
      ghTooltip.style.display = ghShowing ? 'block' : 'none';
      // Close page info tooltip if open
      if (ghShowing && tooltip) tooltip.style.display = 'none';
      if (ghShowing) updateGHStatus(); // Refresh on open
    });
  }

  // Close tooltips on outside click
  document.addEventListener('click', function(e) {
    if (tooltip && infoBtn && !infoBtn.contains(e.target) && !tooltip.contains(e.target)) {
      tooltip.style.display = 'none';
    }
    if (ghTooltip && ghBtn && !ghBtn.contains(e.target) && !ghTooltip.contains(e.target)) {
      ghShowing = false;
      ghTooltip.style.display = 'none';
    }
  });

  // Auto-refresh GitHub status every 60 seconds
  if (ghToken) {
    setInterval(updateGHStatus, 60000);
    // Add pulse animation class if running
    if (ghBtn && ghDot && ghDot.style.background === 'rgb(255, 215, 0)') {
      ghBtn.classList.add('gh-running');
    }
  }
})();
</script>
