---
/**
 * MeetTheFounders - "Meet SAA's Founders" section
 * Uses SAA Astro component library for headings.
 */
import H2 from '../saa/headings/H2.astro';

interface Props {
  variant?: 'default' | 'compact';
}

const { variant = 'default' } = Astro.props;
const isCompact = variant === 'compact';

const SECTION_INTRO = 'Smart Agent Alliance is led by operators, not figureheads. The leadership team is responsible for designing, maintaining, and improving the systems agents rely on every day.';
const SECTION_INTRO_COMPACT = 'Built by operators, not figureheads.';

const FOUNDERS = [
  {
    name: "Doug Smart",
    title: "Co-Founder | Systems & Infrastructure",
    bio: "Doug built SAA\u2019s systems from the ground up \u2014 this website, the agent portal, every automation and workflow agents use daily. As a top 1% eXp team builder, he believes agents deserve better tools than what most sponsors offer, so he builds them. His focus is on creating systems that actually work and showing agents what\u2019s possible when the right infrastructure is behind them.",
    bioCompact: "Full-stack developer and top 1% eXp team builder. Designed and built every system agents use - the portal, automations, marketing tools, and this website.",
    image: "https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/55dbdf32ddc5fbcc-Doug-Profile-Picture.png/public",
  },
  {
    name: "Karrie Hill, JD",
    title: "Co-Founder | Training & Agent Advocacy",
    bio: "UC Berkeley Law graduate and experienced agent who built a six-figure real estate business in her first full year without cold calling or door knocking. Karrie focuses on training design, mentorship standards, and onboarding pathways \u2014 making sure agents have clear structure from day one. Her background as an attorney informs a focus on durability and getting things right.",
    bioCompact: "UC Berkeley Law graduate and eXp Certified Mentor. Built a six-figure real estate business in year one - no cold calls, no door knocking. Leads training and onboarding.",
    image: "https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/4e2a3c105e488654-Karrie-Profile-Picture.png/public",
  },
];

const founderNameShadow = [
  '0 0 0.01em #fff',
  '0 0 0.02em #fff',
  '0 0 0.03em rgba(255,255,255,0.8)',
  '0 0 0.05em #ffd700',
  '0 0 0.09em rgba(255, 215, 0, 0.8)',
  '0 0 0.13em rgba(255, 215, 0, 0.55)',
  '0 0 0.18em rgba(255, 179, 71, 0.35)',
].join(', ');

const cardBg = 'linear-gradient(135deg, rgba(20,20,20,0.95) 0%, rgba(12,12,12,0.98) 100%)';
const cardBorder = '1px solid rgba(255,255,255,0.06)';
const cardShadow = '0 0 0 1px rgba(255,255,255,0.02), 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.03)';
---

<section class="py-[50px] px-6 relative">
  <div class="mx-auto relative z-10" style="max-width: 1500px;">
    <!-- H2 with SVG backing -->
    <div class="text-center mb-12">
      <H2>Meet SAA&apos;s Founders</H2>
      <p class="text-body mt-4 max-w-[800px] mx-auto opacity-80">
        {isCompact ? SECTION_INTRO_COMPACT : SECTION_INTRO}
      </p>
    </div>

    <!-- Two column layout -->
    <div class="grid md:grid-cols-2 gap-8">
      {FOUNDERS.map((founder) => (
        <div>
          <div
            class="p-6 md:p-8 rounded-xl text-center transition-all duration-300 h-full flex flex-col"
            style={`background: ${cardBg}; border: ${cardBorder}; box-shadow: ${cardShadow};`}
          >
            <!-- Profile image -->
            <div class="mx-auto mb-4" style="width: 200px; height: 200px;">
              <img
                src={founder.image}
                alt={founder.name}
                loading="lazy"
                width="200"
                height="200"
                class="w-full h-full object-cover rounded-full"
              />
            </div>
            <!-- Founder name with SVG stroke backing -->
            <div
              data-stroke-config="founder-gold"
              style="position: relative; display: inline-block; width: 100%; overflow: visible; text-align: center;"
            >
              <h3
                class="heading-front font-bold mb-1"
                style={`font-family: var(--font-taskor), serif; font-size: clamp(27px, calc(25.36px + 0.65vw), 45px); line-height: 1.1; color: #ffd700; transform: perspective(800px) rotateX(12deg); font-feature-settings: "ss01" 1; text-align: center; text-shadow: ${founderNameShadow}; position: relative; overflow: visible;`}
              >
                {founder.name}
              </h3>
            </div>
            <p class="text-body text-sm opacity-60 mb-3">{founder.title}</p>
            <p class="text-body text-sm md:text-base leading-relaxed flex-1">
              {isCompact ? founder.bioCompact : founder.bio}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script src="../../scripts/stroke-backing.ts"></script>
