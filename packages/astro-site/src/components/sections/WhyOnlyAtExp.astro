---
/**
 * WhyOnlyAtExp - "Why This Only Works at eXp Realty"
 *
 * Astro port of @public-site/app/components/sections/WhyOnlyAtExp.tsx
 * 3D rotating card stack with auto-flip animation.
 * Uses inline <script> for interactivity (no React).
 */
import H2 from '../saa/headings/H2.astro';

// Content
const HEADLINE = "How eXp Changed Sponsorship";
const STEPS = [
  { num: 1, text: "Most real estate brokerages provide tools, training, and support centrally.", highlight: false },
  { num: 2, text: "Even when sponsorship exists, sponsors are limited to offering only what the brokerage provides.", highlight: false },
  { num: 3, text: "eXp is the only brokerage where sponsors can build and deliver their own systems.", highlight: true },
];
const DIFFERENTIATOR = "SAA Builds What Other Sponsors Can't";
const KEY_POINT = "eXp Realty is the only brokerage that gives sponsors the freedom to build real systems. Most sponsors don't use it. We built a full platform - training, tools, templates, and support - at no cost to our agents.";
const TAGLINE = "When you succeed, we succeed.";

const BRAND_YELLOW = '#ffd700';

const ENTREPRENEURIAL_SPONSOR_IMAGE = 'https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/exp-entrepreneurial-sponsor-v2/desktop';
const ENTREPRENEURIAL_SPONSOR_ALT = 'eXp Realty sponsor delivering entrepreneurial systems to real estate agents';
const ENTREPRENEURIAL_SPONSOR_TITLE = 'eXp Realty Entrepreneurial Sponsor Systems';

// Glass panel styles (gold-tinted)
const glassBg = 'linear-gradient(180deg, rgba(255,215,0,0.03) 0%, rgba(255,215,0,0.04) 50%, rgba(255,215,0,0.03) 100%)';
const glassShadow = '0 8px 32px rgba(0,0,0,0.4), 0 4px 12px rgba(0,0,0,0.25), inset 0 1px 0 0 rgba(255,255,255,0.35), inset 0 2px 4px 0 rgba(255,255,255,0.2), inset 0 8px 20px -8px rgba(255,215,0,0.25), inset 0 20px 40px -20px rgba(255,255,255,0.15), inset 0 -1px 0 0 rgba(0,0,0,0.7), inset 0 -2px 6px 0 rgba(0,0,0,0.5), inset 0 -10px 25px -8px rgba(0,0,0,0.6), inset 0 -25px 50px -20px rgba(0,0,0,0.45)';

// Noise texture SVG (shared with cards)
const noiseSvg = `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E")`;
const cardNoiseSvg = `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.5' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E")`;

// Card backgrounds
const darkBackground = `${cardNoiseSvg}, linear-gradient(135deg, rgba(20,20,20,0.95) 0%, rgba(12,12,12,0.98) 100%)`;
// Highlight card uses same dark bg but with a gold accent border
const highlightBackground = `${cardNoiseSvg}, linear-gradient(135deg, rgba(25,25,20,0.95) 0%, rgba(15,15,10,0.98) 100%)`;

// Number3D styles
// All numbers use gold 3D style (highlight card is now also dark-themed)
const numberStyle = {
  color: '#c4a94d',
  filter: 'drop-shadow(-1px -1px 0 #ffe680) drop-shadow(1px 1px 0 #8a7a3d) drop-shadow(3px 3px 0 #2a2a1d) drop-shadow(4px 4px 2px rgba(0, 0, 0, 0.5))',
  transform: 'perspective(500px) rotateX(8deg)',
};

const totalCards = STEPS.length;
---

<style>
  .woae-card {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    backface-visibility: hidden;
    will-change: transform, opacity;
  }
  .woae-progress-fill {
    transition: width 0.5s ease;
  }
</style>

<section data-woae-section>
  <div
    class="rounded-3xl overflow-hidden relative"
    style={`background: ${glassBg}; box-shadow: ${glassShadow};`}
  >
    {/* Crosshatch texture overlay */}
    <div
      class="absolute inset-0 pointer-events-none z-[1] rounded-3xl"
      style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.08) 0px, transparent 1px, transparent 6px), repeating-linear-gradient(-45deg, rgba(255,255,255,0.08) 0px, transparent 1px, transparent 6px); background-size: 16px 16px;"
    ></div>

    {/* Content */}
    <div class="relative z-10 px-6 py-16 md:py-24">
      <div class="mx-auto" style="max-width: 1600px;">
        {/* Section Header */}
        <div class="text-center mb-10">
          <H2>{HEADLINE}</H2>
        </div>

        <div class="grid min-[1020px]:grid-cols-2 gap-8 items-start">
          {/* Left Column: Card Stack + Progress Bar */}
          <div class="flex flex-col relative" style="z-index: 10;">
            {/* 3D Rotating Card Stack */}
            <div
              class="relative w-full cursor-pointer h-[300px] md:h-[313px]"
              data-woae-stack
              style="perspective: 1200px;"
            >
              {STEPS.map((step, index) => {
                const isActive = index === 0;
                const stackPosition = index;
                const translateZ = isActive ? 0 : -30 * stackPosition;
                const translateY = isActive ? 0 : 20 * stackPosition;
                const opacity = isActive ? 1 : Math.max(0.4, 1 - stackPosition * 0.15);
                const scale = isActive ? 1 : Math.max(0.88, 1 - stackPosition * 0.04);
                const numStyle = numberStyle;

                return (
                  <div
                    class="woae-card absolute inset-0 rounded-2xl p-4 md:p-8 flex flex-col items-center justify-center text-center"
                    data-woae-card={index}
                    style={`
                      background: ${step.highlight ? highlightBackground : darkBackground};
                      background-blend-mode: overlay, normal;
                      border: ${step.highlight ? '2px solid rgba(255,215,0,0.35)' : '1px solid rgba(255,255,255,0.06)'};
                      box-shadow: ${step.highlight
                        ? '0 0 30px 4px rgba(255,215,0,0.15), 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.08)'
                        : '0 0 0 1px rgba(255,255,255,0.02), 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.03)'};
                      transform: perspective(1200px) rotateX(0deg) translate3d(0, ${translateY}px, ${translateZ}px) scale(${scale});
                      transform-origin: center bottom;
                      opacity: ${opacity};
                      z-index: ${totalCards - index};
                    `}
                  >
                    <div
                      class="rounded-full flex items-center justify-center w-12 h-12 md:w-16 md:h-16 mb-3 md:mb-5"
                      style={step.highlight
                        ? 'background: rgba(255,215,0,0.1); border: 2px solid rgba(255,215,0,0.3);'
                        : 'background: rgba(255,255,255,0.08); border: 2px solid rgba(255,255,255,0.15);'}
                    >
                      <span
                        class="inline-flex items-center justify-center font-bold"
                        style={`min-width: 56px; height: 56px; font-size: 32px; color: ${numStyle.color}; filter: ${numStyle.filter}; transform: ${numStyle.transform};`}
                      >{step.num}</span>
                    </div>
                    <p
                      class="font-heading font-bold leading-relaxed px-2"
                      style={`color: #e5e4dd; font-size: clamp(24px, calc(22.55px + 0.58vw), 40px);`}
                    >
                      {step.text}
                    </p>
                  </div>
                );
              })}
            </div>

            {/* Progress Bar */}
            <div class="flex justify-center" style="margin-top: 45px;">
              <div
                class="w-80 h-3 rounded-full overflow-hidden relative"
                style="background: linear-gradient(180deg, #1a1a1a 0%, #2a2a2a 50%, #1a1a1a 100%); border: 1px solid rgba(245, 245, 240, 0.25); box-shadow: inset 0 2px 4px rgba(0,0,0,0.6), inset 0 -1px 2px rgba(255,255,255,0.05);"
              >
                <div
                  class="woae-progress-fill h-full rounded-full"
                  data-woae-progress
                  style={`width: 0%; background: linear-gradient(180deg, #ffe566 0%, ${BRAND_YELLOW} 40%, #cc9900 100%); box-shadow: 0 0 8px ${BRAND_YELLOW}, 0 0 16px ${BRAND_YELLOW}, 0 0 32px ${BRAND_YELLOW}66, inset 0 1px 2px rgba(255,255,255,0.4);`}
                ></div>
              </div>
            </div>

            {/* Click hint */}
            <p class="text-center text-base font-bold text-white/60 mt-3">
              Click to control manually
            </p>
          </div>

          {/* Right Column: Key message card */}
          <figure
            class="relative rounded-2xl overflow-hidden border border-white/10 min-h-[320px] md:min-h-[373px]"
            style="z-index: 1;"
            itemscope
            itemtype="https://schema.org/ImageObject"
          >
            <div class="absolute inset-0">
              <img
                src={ENTREPRENEURIAL_SPONSOR_IMAGE}
                alt={ENTREPRENEURIAL_SPONSOR_ALT}
                title={ENTREPRENEURIAL_SPONSOR_TITLE}
                class="w-full h-full object-cover"
                itemprop="contentUrl"
                loading="lazy"
              />
              <div
                class="absolute inset-0"
                style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.4) 70%, rgba(0,0,0,0.1) 100%);"
              ></div>
            </div>

            <figcaption class="relative z-10 p-6 md:p-8 h-full flex flex-col justify-center">
              <p class="font-heading text-2xl md:text-3xl font-bold mb-4" style={`color: ${BRAND_YELLOW};`}>{DIFFERENTIATOR}</p>
              <p class="text-body text-lg leading-relaxed mb-4" itemprop="description">{KEY_POINT}</p>
              <p class="text-body text-xl italic mb-6" style={`color: ${BRAND_YELLOW};`}>{TAGLINE}</p>
            </figcaption>

            <meta itemprop="name" content={ENTREPRENEURIAL_SPONSOR_TITLE} />
          </figure>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // WhyOnlyAtExp - card stack auto-flip with vanilla JS
  (function () {
    const section = document.querySelector('[data-woae-section]');
    if (!section) return;

    const stack = section.querySelector('[data-woae-stack]');
    const cards = section.querySelectorAll('[data-woae-card]');
    const progressBar = section.querySelector('[data-woae-progress]') as HTMLElement;
    if (!stack || cards.length === 0 || !progressBar) return;

    const totalCards = cards.length;
    let currentCard = 0;
    let isAutoMode = true;
    let hasStarted = false;
    let timer: ReturnType<typeof setInterval> | null = null;

    function updateCards() {
      const progress = currentCard / (totalCards - 1);
      progressBar.style.width = `${progress * 100}%`;

      cards.forEach((card, index) => {
        const el = card as HTMLElement;
        let rotateX = 0, translateZ = 0, translateY = 0, opacity = 1, scale = 1;

        if (index === currentCard) {
          rotateX = 0; opacity = 1; scale = 1; translateZ = 0; translateY = 0;
        } else if (index < currentCard) {
          rotateX = -90; opacity = 0; scale = 0.9;
        } else {
          const stackPosition = index - currentCard;
          translateZ = -30 * stackPosition;
          translateY = 20 * stackPosition;
          opacity = Math.max(0.4, 1 - stackPosition * 0.15);
          scale = Math.max(0.88, 1 - stackPosition * 0.04);
        }

        el.style.transform = `perspective(1200px) rotateX(${rotateX}deg) translate3d(0, ${translateY}px, ${translateZ}px) scale(${scale})`;
        el.style.opacity = String(opacity);
        el.style.zIndex = String(totalCards - index);
      });
    }

    function advance() {
      currentCard = (currentCard + 1) % totalCards;
      updateCards();
    }

    function startAutoFlip() {
      if (timer) clearInterval(timer);
      timer = setInterval(advance, 4000);
    }

    // Click handler
    stack.addEventListener('click', () => {
      if (isAutoMode) {
        isAutoMode = false;
        if (timer) { clearInterval(timer); timer = null; }
      }
      advance();
    });

    // IntersectionObserver - start when 20% visible
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting && entry.intersectionRatio >= 0.2 && !hasStarted) {
          hasStarted = true;
          if (isAutoMode) startAutoFlip();
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(section);
  })();
</script>
