---
/**
 * HeroSection - Homepage hero with Doug & Karrie image, H1, tagline, CTA
 *
 * Pure static HTML. The JoinAllianceCTA button is a tiny React island
 * for the modal trigger. Everything else is zero JS.
 */
import H1 from '../saa/headings/H1.astro';
import Tagline from '../saa/headings/Tagline.astro';
---

<section
  class="relative min-h-[100dvh] w-full"
  aria-label="Hero"
  style="max-width: 3000px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: visible;"
>
  <!-- RevealMaskEffect golden glow (React island, placed behind content) -->
  <slot name="effect" />

  <!-- Hero Content Block -->
  <div
    class="hero-content-wrapper flex flex-col items-center w-full pt-[8%] md:pt-0"
    style="max-width: 3000px; overflow: visible;"
  >
    <!-- Doug and Karrie Image Container -->
    <div
      class="relative pointer-events-none z-[1]"
      style="width: clamp(400px, 47.37vw, 900px); max-width: 95vw; aspect-ratio: 900 / 500; max-height: 50dvh; overflow: visible;"
    >
      <!-- Space cloud/mist backdrop -->
      <div
        class="hero-3d-backdrop absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%]"
        style="background: radial-gradient(ellipse 60% 50% at center 45%, rgba(100,80,150,0.15) 0%, rgba(50,40,80,0.1) 40%, transparent 70%); filter: blur(40px);"
      ></div>
      <!-- Main image -->
      <img
        src="https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop"
        srcset="
          https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/mobile 375w,
          https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/tablet 768w,
          https://imagedelivery.net/RZBQ4dWu2c_YEpklnDDxFg/doug-and-karrie-co-founders/desktop 1280w
        "
        sizes="(max-width: 480px) 375px, (max-width: 768px) 768px, 1280px"
        alt="Doug and Karrie - Co-founders of Smart Agent Alliance"
        width="900"
        height="500"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero-3d-image profile-image w-full h-full object-contain"
        style="mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 70%, rgba(0,0,0,0.9) 80%, rgba(0,0,0,0.6) 88%, rgba(0,0,0,0.3) 94%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 0%, rgba(0,0,0,1) 70%, rgba(0,0,0,0.9) 80%, rgba(0,0,0,0.6) 88%, rgba(0,0,0,0.3) 94%, transparent 100%);"
      />
    </div>

    <!-- H1, Tagline, and Buttons - pulls up to overlap bottom 25% of image -->
    <div
      class="w-full px-4 sm:px-8 md:px-12 text-center pointer-events-auto z-[2]"
      style="max-width: 3000px; margin-top: calc(min(clamp(400px, 47.37vw, 900px) / 7.2, 12.5dvh) * -1);"
    >
      <!-- Headline Group -->
      <div style="perspective: 1000px;" class="relative">
        <div class="relative z-10">
          <H1 id="hero-heading" style={{ marginBottom: '3px' }}>
            SMART AGENT ALLIANCE
          </H1>
          <Tagline class="hero-tagline-mobile-spacing" style={{ marginBottom: '2px' }}>
            For Agents Who Want More
          </Tagline>
          <p class="text-body opacity-90" style="margin-bottom: 6px;">
            Smart Agent Alliance costs agents nothing. Every system is delivered through our agent portal.
          </p>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="hero-cta-buttons flex justify-center items-center" style="margin-top: 14px;">
        <slot name="cta" />
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero-specific CSS (from hero.css) */
  .profile-image {
    color: transparent;
    font-size: 0;
    text-indent: -9999px;
  }

  .hero-3d-backdrop {
    transform-style: flat;
    transform: none;
  }

  .hero-3d-image {
    transform-style: flat;
    transform: translate3d(0, 0, 0);
    will-change: opacity;
  }

  @media (min-width: 768px) {
    .hero-3d-image {
      transform-style: preserve-3d;
      transform: translateZ(-50px) rotateX(5deg);
    }
  }

  .hero-content-wrapper {
    will-change: transform, opacity, filter;
  }

  .hero-content-wrapper *:not(.hero-3d-image) {
    backface-visibility: hidden;
  }

  .hero-tagline-mobile-spacing {
    margin-top: 20px;
  }
</style>
