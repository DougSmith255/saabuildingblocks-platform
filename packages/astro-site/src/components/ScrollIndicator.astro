---
/**
 * ScrollIndicator - Simple bouncing double chevron (center bottom).
 * ALL CSS is injected via is:inline <style> to bypass Astro CSS pipeline entirely.
 * Bounce + fade animation, fades on scroll.
 */
---

<style is:inline>
@keyframes si-bounce-kf {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(10px); }
}
@keyframes si-fade-down-kf {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.15; }
}
@keyframes si-fade-up-kf {
  0%, 100% { opacity: 0.15; }
  50% { opacity: 1; }
}
#scroll-indicator-wrap {
  position: fixed;
  bottom: max(28px, calc(env(safe-area-inset-bottom, 0px) + 16px));
  left: 50%;
  transform: translateX(-50%);
  z-index: -1;
  pointer-events: none;
  transition: opacity 0.3s ease-out;
}
#scroll-indicator-bounce {
  animation: si-bounce-kf 1.8s ease-in-out infinite;
}
#scroll-indicator-top {
  animation: si-fade-down-kf 1.8s ease-in-out infinite;
}
#scroll-indicator-bottom {
  animation: si-fade-up-kf 1.8s ease-in-out infinite;
}
@media (prefers-reduced-motion: reduce) {
  #scroll-indicator-bounce,
  #scroll-indicator-top,
  #scroll-indicator-bottom {
    animation: none !important;
  }
}
</style>

<div id="scroll-indicator-wrap" aria-hidden="true">
  <div id="scroll-indicator-bounce">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="filter:drop-shadow(0 0 3px rgba(229,228,221,0.3));">
      <path id="scroll-indicator-top" d="M7 6l5 5 5-5" stroke="#e5e4dd" />
      <path id="scroll-indicator-bottom" d="M7 13l5 5 5-5" stroke="#e5e4dd" />
    </svg>
  </div>
</div>

<script is:inline>
(function() {
  var el = document.getElementById('scroll-indicator-wrap');
  if (!el) return;
  var ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(function() {
      var y = window.scrollY;
      el.style.opacity = y <= 20 ? '1' : y >= 120 ? '0' : String(1 - (y - 20) / 100);
      ticking = false;
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
