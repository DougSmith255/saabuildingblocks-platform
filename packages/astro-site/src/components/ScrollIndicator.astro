---
/**
 * ScrollIndicator - Simple bouncing double chevron at bottom of first viewport.
 * Positioned absolutely so it scrolls with the page.
 * ALL CSS is injected via is:inline <style> to bypass Astro CSS pipeline.
 */
---

<style is:inline>
@keyframes si-bounce-kf {
  0%, 100% {
    transform: translateY(-25%) translateX(-50%);
    animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
  }
  50% {
    transform: translateY(0) translateX(-50%);
    animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
  }
}
#scroll-indicator-wrap {
  position: absolute;
  top: calc(100svh - 50px);
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  pointer-events: none;
  animation: si-bounce-kf 1s infinite;
}
@media (prefers-reduced-motion: reduce) {
  #scroll-indicator-wrap {
    animation: none !important;
  }
}
</style>

<div id="scroll-indicator-wrap" aria-hidden="true">
  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="filter:drop-shadow(0 0 3px rgba(229,228,221,0.3));">
    <path d="M7 6l5 5 5-5" stroke="#e5e4dd" />
    <path d="M7 13l5 5 5-5" stroke="#e5e4dd" />
  </svg>
</div>
