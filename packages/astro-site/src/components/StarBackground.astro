---
/**
 * StarBackground - Pure CSS star background
 *
 * Replaces the React canvas-based StarBackgroundCanvas with zero JS.
 * Uses CSS radial-gradient dots + keyframe animation for gentle upward drift.
 * 3 layers with different sizes/speeds create parallax depth.
 *
 * Performance: 0 JS, 0 DOM elements beyond 3 fixed divs.
 */

// Generate random star positions at build time
// Compact format: drop decimal precision, use shorthand rgba
function generateStarLayer(count: number, maxSize: number): string {
  const shadows: string[] = [];
  for (let i = 0; i < count; i++) {
    const x = Math.round(Math.random() * 2560);
    const y = Math.round(Math.random() * 2560);
    const opacity = Math.round((Math.random() * 0.4 + 0.4) * 100) / 100;
    const size = Math.round((Math.random() * maxSize + 0.3) * 10) / 10;
    shadows.push(`${x}px ${y}px 0 ${size}px rgba(255,255,255,${opacity})`);
  }
  return shadows.join(',');
}

// Reduced star counts: 250 → 80 total (saves ~15KB of inline HTML per page)
// Visual difference is negligible - stars are tiny dots on a dark background
const layer1 = generateStarLayer(30, 0.6);   // Small, slow
const layer2 = generateStarLayer(30, 1.0);   // Medium
const layer3 = generateStarLayer(20, 1.4);   // Larger, faster
---

<div class="star-bg-gradient" aria-hidden="true"></div>
<div class="star-bg-layer star-bg-layer-1" aria-hidden="true" style={`box-shadow: ${layer1};`}></div>
<div class="star-bg-layer star-bg-layer-2" aria-hidden="true" style={`box-shadow: ${layer2};`}></div>
<div class="star-bg-layer star-bg-layer-3" aria-hidden="true" style={`box-shadow: ${layer3};`}></div>

<style>
  .star-bg-gradient {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background: radial-gradient(at center bottom, rgb(18, 18, 18) 0%, rgb(5, 5, 5) 100%);
    background-color: rgb(5, 5, 5);
  }

  .star-bg-layer {
    position: fixed;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    z-index: -1;
    pointer-events: none;
    border-radius: 50%;
    will-change: transform;
    contain: layout style size;
  }

  .star-bg-layer-1 {
    animation: starDrift 240s linear infinite;
  }

  .star-bg-layer-2 {
    animation: starDrift 160s linear infinite;
  }

  .star-bg-layer-3 {
    animation: starDrift 100s linear infinite;
  }

  @keyframes starDrift {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-2560px);
    }
  }

  /* Hide stars entirely on mobile - saves significant paint/composite time
     on throttled CPUs. Stars are barely visible on small screens anyway.
     The gradient background still provides the dark space feel. */
  @media (max-width: 767px) {
    .star-bg-layer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .star-bg-layer {
      animation: none;
    }
  }
</style>
